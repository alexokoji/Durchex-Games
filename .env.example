# ─── Frontend (Vite) ──────────────────────────────────────────────────────
# All variables prefixed with VITE_ are exposed to the browser. Never put
# secrets here — only public URLs and public keys.

# Base URL of the API. Leave EMPTY when relying on the Vite dev proxy
# (recommended in development). For production set the absolute origin,
# e.g. VITE_API_BASE_URL=https://api.duchexigames.com
VITE_API_BASE_URL=http://localhost:27017

# Where Socket.IO connects. Leave empty to use the same origin as the API.
VITE_SOCKET_URL=

# Optional: Flutterwave public key, used only if we ever switch to the
# inline widget. The hosted Standard checkout (default) does NOT need this
# on the frontend — the backend opens the session and gives us a URL.
VITE_FLUTTERWAVE_PUBLIC_KEY=

# Currency the deposit modal defaults to. Flutterwave will accept NGN, USD,
# GHS, KES, RWF, UGX, ZMW and a handful of others depending on your account.
VITE_DEFAULT_FIAT=NGN
