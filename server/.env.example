# ─── server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
PUBLIC_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173

# Comma-separated list of allowed CORS origins for the API.
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ─── mongo ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/duchexigames

# ─── jwt ───────────────────────────────────────────────────────────────────
# REQUIRED: long random string used to sign access & refresh tokens.
JWT_SECRET=replace-me-with-a-64-char-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ─── email (nodemailer SMTP) ──────────────────────────────────────────────
# Used for email-verification and password-reset links.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="DURCHEXiGAMES <no-reply@durchexigames.com>"

# ─── google oauth ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match exactly what's in your Google Cloud OAuth consent screen.
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# ─── apple oauth ───────────────────────────────────────────────────────────
# All four are required to enable Sign-in-with-Apple.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Path to the .p8 file you downloaded from Apple Developer.
APPLE_PRIVATE_KEY_PATH=
APPLE_CALLBACK_URL=http://localhost:4000/api/auth/apple/callback

# ─── flutterwave ───────────────────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
# String you set on the Flutterwave dashboard; webhooks include this in headers.
FLUTTERWAVE_WEBHOOK_HASH=
# Where Flutterwave redirects the customer after payment.
FLUTTERWAVE_REDIRECT_URL=http://localhost:5173/wallet/return

# ─── economy ───────────────────────────────────────────────────────────────
# Starting balance (BTC) for new accounts; set to 0 for production.
WELCOME_BONUS_BTC=0
# Min/max in BTC for a single deposit and withdrawal.
DEPOSIT_MIN_BTC=0.0001
DEPOSIT_MAX_BTC=10
WITHDRAW_MIN_BTC=0.0005
WITHDRAW_MAX_BTC=5
